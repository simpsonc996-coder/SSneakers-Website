# Backend environment variables for SSneakers
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/sneaker_rabbit
JWT_SECRET=your_jwt_secret_here

# KicksDB API key for external sneaker metadata searches
KICKSDB_API_KEY=your_kicksdb_api_key_here

# PayPal settings (optional)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_MODE=sandbox

# Cloudinary upload settings (optional)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
